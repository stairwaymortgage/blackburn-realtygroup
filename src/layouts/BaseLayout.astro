---
// BaseLayout.astro — wraps every page with Nav and Footer automatically.
// Pages just supply their content via <slot />. Title and meta come in as props.
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  theme?: 'default' | 'ladies' | 'guys' | 'story' | 'tools' | 'diy' | 'keyes' | 'contact' | 'blog';
  canonical?: string;
}

const {
  title,
  description = "Florida's front door to the world. A division of The Keyes Company. 50 languages, 1 standard, 1 team.",
  theme = 'default',
  canonical,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Blackburn Realty Group" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Nav />

    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>
