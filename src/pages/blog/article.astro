<script is:inline>
  (function () {
    var els = document.querySelectorAll('.reveal');
    if (!('IntersectionObserver' in window)) { els.forEach(function(e){e.classList.add('is-in');}); return; }
    var io = new IntersectionObserver(function(entries){ entries.forEach(function(en){ if(en.isIntersecting){ en.target.classList.add('is-in'); io.unobserve(en.target);} }); }, { threshold: 0.1, rootMargin: '0px 0px -6% 0px' });
    els.forEach(function(e){ io.observe(e); });
  })();
</script>

