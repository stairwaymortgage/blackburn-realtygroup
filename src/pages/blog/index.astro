---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { IMAGES, SHOW_IMAGE_LABELS } from '../../data/images';
---

<BaseLayout theme="blog" title="Blog | Blackburn Realty Group" description="Stories, market insights, and analysis from Florida's international real estate team.">

<section class="blog-hub-hero reveal" style={`--blog-hero-img: url('${IMAGES.blogHero.src}')`}>
  <div class="blog-hero-veil"></div>
  <div class="blog-hub-hero-inner">
    <p class="blog-hub-eyebrow">Insights &amp; Intelligence</p>
    <h1 class="blog-hub-title">The Blackburn <em>Journal</em></h1>
    <p class="blog-hub-sub">Florida real estate insights, international buyer guides, financing breakdowns, and cultural market intelligence &mdash; published in 50 languages.</p>

    <div class="cat-bar"><button class="cat-pill active">All</button><button class="cat-pill ">International Buyers</button><button class="cat-pill ">Financing</button><button class="cat-pill ">Market Trends</button><button class="cat-pill ">Buyer Education</button><button class="cat-pill ">Seller Education</button><button class="cat-pill ">Cultural Markets</button><button class="cat-pill ">Investment</button><button class="cat-pill ">DIY Resources</button></div>
  </div>
  {SHOW_IMAGE_LABELS && !IMAGES.blogHero.team && (
    <div class="blog-hero-imglabel">Image · {IMAGES.blogHero.intent}</div>
  )}
</section>

<section class="featured-section reveal">
  <a href="/blog/article/" class="featured-card">
    <img src="https://images.pexels.com/photos/2096700/pexels-photo-2096700.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Why Spanish-Speaking Buyers Are Quietly Reshaping South Florida" class="featured-image" />
    <div class="featured-content">
      <div class="featured-label">Featured Article</div>
      <h2 class="featured-title">Why Spanish-Speaking Buyers Are Quietly Reshaping South Florida</h2>
      <p class="featured-excerpt">From Madrid to Buenos Aires, Spanish speakers now represent the largest international buyer pool entering the Florida market. Here is what every buyer should know.</p>
      <div class="featured-meta">International Buyers &middot; March 12, 2026 &middot; 8 min read</div>
      <span class="featured-read-more">Read the Article &rarr;</span>
    </div>
  </a>
</section>

<section class="post-grid-section reveal">
  <div class="post-grid">
    <a href="/blog/article/" class="post-card">
      <div class="post-image-wrap">
        <img src="https://images.pexels.com/photos/3760067/pexels-photo-3760067.jpeg?auto=compress&cs=tinysrgb&w=800" alt="DSCR Loans for Foreign National Investors: The Complete Breakdown" class="post-image" loading="lazy" />
      </div>
      <div class="post-meta">
        <span class="post-category">Financing</span>
        <span class="post-dot">&middot;</span>
        <span class="post-date">March 8, 2026</span>
      </div>
      <h3 class="post-title">DSCR Loans for Foreign National Investors: The Complete Breakdown</h3>
      <p class="post-excerpt">How non-resident investors are financing Florida investment properties without US tax returns or credit history.</p>
      <span class="post-read">12 min read &middot; Read Article &rarr;</span>
    </a>
    <a href="/blog/article/" class="post-card">
      <div class="post-image-wrap">
        <img src="https://images.pexels.com/photos/2079246/pexels-photo-2079246.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Miami Pre-Construction in 2026: What International Buyers Need to Know" class="post-image" loading="lazy" />
      </div>
      <div class="post-meta">
        <span class="post-category">Market Trends</span>
        <span class="post-dot">&middot;</span>
        <span class="post-date">March 2, 2026</span>
      </div>
      <h3 class="post-title">Miami Pre-Construction in 2026: What International Buyers Need to Know</h3>
      <p class="post-excerpt">Inside the new Brickell and Edgewater towers being marketed heavily to Latin American and European capital.</p>
      <span class="post-read">10 min read &middot; Read Article &rarr;</span>
    </a>
    <a href="/blog/article/" class="post-card">
      <div class="post-image-wrap">
        <img src="https://images.pexels.com/photos/2102587/pexels-photo-2102587.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Florida Property Taxes Explained for International Buyers" class="post-image" loading="lazy" />
      </div>
      <div class="post-meta">
        <span class="post-category">Buyer Education</span>
        <span class="post-dot">&middot;</span>
        <span class="post-date">February 24, 2026</span>
      </div>
      <h3 class="post-title">Florida Property Taxes Explained for International Buyers</h3>
      <p class="post-excerpt">Homestead exemption, Save Our Homes, non-resident taxation, and why no state income tax does not mean no tax burden.</p>
      <span class="post-read">7 min read &middot; Read Article &rarr;</span>
    </a>
    <a href="/blog/article/" class="post-card">
      <div class="post-image-wrap">
        <img src="https://images.pexels.com/photos/3992656/pexels-photo-3992656.jpeg?auto=compress&cs=tinysrgb&w=800" alt="The Quiet Strength of Broward's Haitian-American Buyer Market" class="post-image" loading="lazy" />
      </div>
      <div class="post-meta">
        <span class="post-category">Cultural Markets</span>
        <span class="post-dot">&middot;</span>
        <span class="post-date">February 18, 2026</span>
      </div>
      <h3 class="post-title">The Quiet Strength of Broward's Haitian-American Buyer Market</h3>
      <p class="post-excerpt">Generational wealth, first-time buyers, and the underserved community shaping North Miami and Pembroke Pines.</p>
      <span class="post-read">9 min read &middot; Read Article &rarr;</span>
    </a>
    <a href="/blog/article/" class="post-card">
      <div class="post-image-wrap">
        <img src="https://images.pexels.com/photos/2034335/pexels-photo-2034335.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Why Vietnamese Investors Are Buying Orlando, Not Miami" class="post-image" loading="lazy" />
      </div>
      <div class="post-meta">
        <span class="post-category">Investment</span>
        <span class="post-dot">&middot;</span>
        <span class="post-date">February 11, 2026</span>
      </div>
      <h3 class="post-title">Why Vietnamese Investors Are Buying Orlando, Not Miami</h3>
      <p class="post-excerpt">Tourism rentals, Disney proximity, and the math that pencils out for Asian capital looking for cash flow over appreciation.</p>
      <span class="post-read">11 min read &middot; Read Article &rarr;</span>
    </a>
    <a href="/blog/article/" class="post-card">
      <div class="post-image-wrap">
        <img src="https://images.pexels.com/photos/2102568/pexels-photo-2102568.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Aventura: The Quiet Capital of Russian and Israeli Buyers" class="post-image" loading="lazy" />
      </div>
      <div class="post-meta">
        <span class="post-category">Cultural Markets</span>
        <span class="post-dot">&middot;</span>
        <span class="post-date">February 4, 2026</span>
      </div>
      <h3 class="post-title">Aventura: The Quiet Capital of Russian and Israeli Buyers</h3>
      <p class="post-excerpt">How one ZIP code became the gateway for Russian-speaking and Hebrew-speaking buyers entering South Florida real estate.</p>
      <span class="post-read">8 min read &middot; Read Article &rarr;</span>
    </a>
    <a href="/blog/article/" class="post-card">
      <div class="post-image-wrap">
        <img src="https://images.pexels.com/photos/4246109/pexels-photo-4246109.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Selling a Florida Home During Divorce: A Calm, Practical Guide" class="post-image" loading="lazy" />
      </div>
      <div class="post-meta">
        <span class="post-category">Seller Education</span>
        <span class="post-dot">&middot;</span>
        <span class="post-date">January 28, 2026</span>
      </div>
      <h3 class="post-title">Selling a Florida Home During Divorce: A Calm, Practical Guide</h3>
      <p class="post-excerpt">Court-ordered sales, equitable distribution, and how to navigate a sale when emotions are high and timing matters.</p>
      <span class="post-read">10 min read &middot; Read Article &rarr;</span>
    </a>
    <a href="/blog/article/" class="post-card">
      <div class="post-image-wrap">
        <img src="https://images.pexels.com/photos/3935320/pexels-photo-3935320.jpeg?auto=compress&cs=tinysrgb&w=800" alt="The Truth About For Sale By Owner in Florida (From Someone Who Wants You to Win)" class="post-image" loading="lazy" />
      </div>
      <div class="post-meta">
        <span class="post-category">DIY Resources</span>
        <span class="post-dot">&middot;</span>
        <span class="post-date">January 21, 2026</span>
      </div>
      <h3 class="post-title">The Truth About For Sale By Owner in Florida (From Someone Who Wants You to Win)</h3>
      <p class="post-excerpt">An honest agent walks through when FSBO makes sense, when it costs you tens of thousands, and what most owners get wrong.</p>
      <span class="post-read">13 min read &middot; Read Article &rarr;</span>
    </a>
  </div>
</section>

<div class="newsletter-strip">
  <p class="newsletter-eyebrow">Stay Informed</p>
  <h2 class="newsletter-title">Get insights in <em>your language.</em></h2>
  <p class="newsletter-sub">Monthly market intelligence and buyer guides delivered to your inbox. Available in 50 languages. Unsubscribe any time.</p>
  <div class="newsletter-form">
    <input type="email" class="newsletter-input" placeholder="your@email.com" />
    <button class="newsletter-submit">Subscribe</button>
  </div>
</div>

<section class="cta-strip">
  <div class="cta-strip-inner">
    <p class="cta-strip-eyebrow">Ready to Take Action?</p>
    <h2 class="cta-strip-headline">Reading is good. <em>Doing is better.</em></h2>
    <p class="cta-strip-body">Connect with one of our 100 bilingual agents and move from research mode to action mode.</p>
    <div class="cta-buttons">
      <a href="/ladies/" class="btn-primary">Find Your Agent</a>
      <a href="/tools/consultation/" class="btn-secondary">Book a Consultation</a>
    </div>
  </div>
</section>

<div class="mobile-sticky">
  <a href="/ladies/" class="mobile-sticky-btn">Find My Agent</a>
  <a href="/tools/preapproval/" class="mobile-sticky-btn">Get Pre-Approved</a>
  <a href="/tools/homevalue/" class="mobile-sticky-btn">Home Value</a>
</div>


<script is:inline>
  (function () {
    var els = document.querySelectorAll('.reveal');
    if (!('IntersectionObserver' in window)) { els.forEach(function (e) { e.classList.add('is-in'); }); return; }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) { entry.target.classList.add('is-in'); io.unobserve(entry.target); }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -6% 0px' });
    els.forEach(function (e) { io.observe(e); });
  })();
</script>

</BaseLayout>

<style is:global>
    .nav-item > a:hover { color: var(--white); }
    .nav-item.active > 
    .nav-item.active-ladies > 
    .nav-item.active-guys > 
    
    .nav-item:nth-last-child(-n+3) 
    .nav-item:hover 
    .nav-dropdown a:last-child { border-bottom: none; }
    .nav-dropdown a:hover { color: var(--white); background: rgba(255,255,255,0.03); padding-left: 30px; }
    .nav-dropdown a.ladies { border-left: 2px solid var(--pink); }
    .nav-dropdown a.guys { border-left: 2px solid var(--turquoise); }
    .nav-dropdown a.ladies:hover { color: var(--pink); }
    .nav-dropdown a.guys:hover { color: var(--turquoise); }

    /* breadcrumb */

    .breadcrumb-inner a:hover { color: var(--theme); }

    /* page hero shared */
    .page-hero {
      padding: 60px 52px 80px;
      max-width: 1200px; margin: 0 auto;
      text-align: center;
    }
    .page-eyebrow {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.72rem;
      letter-spacing: 0.4em; color: var(--theme);
      text-transform: uppercase; margin-bottom: 24px;
    }
    .page-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300; font-size: clamp(2.8rem, 6vw, 5rem);
      letter-spacing: 0.02em; color: var(--white);
      line-height: 1; margin-bottom: 24px;
    }
    .page-title em { font-style: italic; color: var(--theme); }
    .page-sub {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-weight: 300;
      font-size: clamp(1.15rem, 2.2vw, 1.5rem);
      color: var(--silver); max-width: 720px; margin: 0 auto;
      line-height: 1.5;
    }

    /* sections */
    .section {
      padding: 80px 52px;
      max-width: 1100px; margin: 0 auto;
    }
    .section-wide { max-width: 1400px; }
    .section h2 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300; font-size: clamp(2rem, 4.2vw, 3.2rem);
      color: var(--white); line-height: 1.15; margin-bottom: 28px;
      letter-spacing: 0.01em;
    }
    .section h2 em { font-style: italic; color: var(--theme); }
    .section h3 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 500; font-size: 1.5rem;
      color: var(--white); margin-bottom: 14px;
    }
    .section-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.7rem;
      letter-spacing: 0.38em; color: var(--theme);
      text-transform: uppercase; margin-bottom: 20px;
    }
    .section p {
      font-family: 'Barlow', sans-serif;
      font-weight: 300; font-size: 1rem;
      line-height: 1.95; color: var(--silver-mid);
      margin-bottom: 24px;
    }
    .section p.lead {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-weight: 300;
      font-size: 1.4rem; color: var(--silver-light);
      line-height: 1.55; margin-bottom: 36px;
    }

    .section-rule {
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(255,255,255,0.08), transparent);
      max-width: 1100px; margin: 0 auto;
    }

    /* buttons */

    /* final cta strip */

    .cta-strip-headline em { font-style: italic; color: var(--theme); }

    /* footer */

    .footer-links a:hover { color: var(--silver-light); }

    /* mobile sticky */
    .mobile-sticky {
      display: none;
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 90;
      background: rgba(6,6,6,0.97);
      border-top: 1px solid rgba(255,255,255,0.08);
      padding: 12px 16px; gap: 8px;
      backdrop-filter: blur(12px);
    }
    .mobile-sticky-btn {
      flex: 1;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 600; font-size: 0.6rem;
      letter-spacing: 0.18em; text-transform: uppercase;
      text-align: center; text-decoration: none;
      padding: 12px 8px;
      border: 1px solid rgba(255,255,255,0.12);
      color: var(--silver-light);
      transition: all 0.2s;
    }
    .mobile-sticky-btn:hover { background: rgba(255,255,255,0.06); }

    /* mobile */
    @media (max-width: 860px) {

      .mobile-sticky { display: flex; }
      
      .page-hero { padding: 40px 22px 50px; }
      .section { padding: 60px 22px; }

    }

    .blog-hub-hero {
      padding: 100px 52px 60px;
      max-width: 1300px;
      margin: 0 auto;
      text-align: center;
    }
    .blog-hub-eyebrow {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.72rem;
      letter-spacing: 0.4em; color: var(--theme);
      text-transform: uppercase; margin-bottom: 24px;
    }
    .blog-hub-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300; font-size: clamp(2.8rem, 6vw, 5rem);
      letter-spacing: 0.02em; color: var(--white);
      line-height: 1; margin-bottom: 20px;
    }
    .blog-hub-title em { font-style: italic; color: var(--theme); }
    .blog-hub-sub {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-weight: 300;
      font-size: 1.4rem; color: var(--silver);
      max-width: 760px; margin: 0 auto;
    }

    /* CATEGORY PILLS */
    .cat-bar {
      max-width: 1300px;
      margin: 40px auto 0;
      padding: 0 52px;
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: center;
    }
    .cat-pill {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.7rem;
      letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--silver-dark);
      background: transparent;
      border: 1px solid rgba(255,255,255,0.1);
      padding: 10px 20px;
      cursor: pointer;
      transition: all 0.2s;
    }
    .cat-pill:hover { color: var(--white); border-color: var(--silver-dark); }
    .cat-pill.active {
      color: var(--black); background: var(--theme); border-color: var(--theme);
    }

    /* FEATURED POST */
    .featured-section {
      max-width: 1300px;
      margin: 80px auto;
      padding: 0 52px;
    }
    .featured-card {
      display: grid;
      grid-template-columns: 1.3fr 1fr;
      gap: 60px;
      align-items: center;
      text-decoration: none;
      background: var(--near-black);
      border: 1px solid rgba(255,255,255,0.06);
      overflow: hidden;
      transition: border-color 0.3s;
    }
    .featured-card:hover { border-color: rgba(232,232,232,0.4); }
    .featured-image {
      width: 100%;
      aspect-ratio: 3/2;
      object-fit: cover;
      filter: grayscale(15%);
      transition: filter 0.4s;
    }
    .featured-card:hover .featured-image { filter: grayscale(0%); }
    .featured-content { padding: 48px 48px 48px 0; }
    .featured-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 600; font-size: 0.68rem;
      letter-spacing: 0.32em; color: var(--theme);
      text-transform: uppercase; margin-bottom: 18px;
    }
    .featured-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 400; font-size: clamp(1.8rem, 3.4vw, 2.6rem);
      line-height: 1.2; color: var(--white); margin-bottom: 18px;
    }
    .featured-excerpt {
      font-family: 'Barlow', sans-serif;
      font-weight: 300; font-size: 1.02rem;
      line-height: 1.85; color: var(--silver-mid);
      margin-bottom: 22px;
    }
    .featured-read-more {
      display: inline-block;
      margin-top: 24px;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 600; font-size: 0.72rem;
      letter-spacing: 0.25em; color: var(--theme);
      text-transform: uppercase;
    }

    /* POST GRID */
    .post-grid-section {
      max-width: 1300px;
      margin: 0 auto;
      padding: 0 52px 80px;
    }
    .post-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 36px;
    }
    .post-card {
      text-decoration: none;
      display: flex;
      flex-direction: column;
      transition: transform 0.3s;
    }
    .post-card:hover { transform: translateY(-4px); }
    .post-image-wrap {
      width: 100%;
      aspect-ratio: 3/2;
      overflow: hidden;
      margin-bottom: 22px;
      background: var(--charcoal);
    }
    .post-image {
      width: 100%; height: 100%;
      object-fit: cover;
      filter: grayscale(15%);
      transition: all 0.4s;
    }
    .post-card:hover .post-image {
      filter: grayscale(0%);
      transform: scale(1.04);
    }
    .post-category {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 600; font-size: 0.62rem;
      letter-spacing: 0.28em; color: var(--theme);
      text-transform: uppercase;
    }
    .post-dot, .post-date {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 400; font-size: 0.62rem;
      letter-spacing: 0.18em; color: var(--silver-dark);
      text-transform: uppercase;
    }
    .post-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 500; font-size: 1.35rem;
      line-height: 1.25; color: var(--white);
      margin-bottom: 12px;
      transition: color 0.2s;
    }
    .post-card:hover .post-title { color: var(--theme); }
    .post-excerpt {
      font-family: 'Barlow', sans-serif;
      font-weight: 300; font-size: 0.92rem;
      line-height: 1.75; color: var(--silver-dark);
      margin-bottom: 14px;
      flex: 1;
    }
    .post-read {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.66rem;
      letter-spacing: 0.22em; color: var(--silver-mid);
      text-transform: uppercase;
    }

    /* NEWSLETTER STRIP */
    .newsletter-strip {
      max-width: 1100px;
      margin: 0 auto;
      padding: 80px 52px;
      text-align: center;
      border-top: 1px solid rgba(255,255,255,0.05);
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .newsletter-eyebrow {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.7rem;
      letter-spacing: 0.4em; color: var(--theme);
      text-transform: uppercase; margin-bottom: 18px;
    }
    .newsletter-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300; font-size: clamp(1.8rem, 3.8vw, 2.6rem);
      color: var(--white); margin-bottom: 16px;
      line-height: 1.2;
    }
    .newsletter-title em { font-style: italic; color: var(--theme); }
    .newsletter-sub {
      font-family: 'Barlow', sans-serif;
      font-weight: 300; font-size: 0.95rem;
      color: var(--silver-dark);
      margin-bottom: 32px;
      max-width: 560px; margin-left: auto; margin-right: auto;
    }
    .newsletter-form {
      display: flex;
      gap: 0;
      max-width: 540px;
      margin: 0 auto;
    }
    .newsletter-input {
      flex: 1;
      font-family: 'Barlow', sans-serif;
      font-size: 0.95rem;
      color: var(--white);
      background: var(--near-black);
      border: 1px solid rgba(255,255,255,0.1);
      padding: 16px 20px;
    }
    .newsletter-input:focus { outline: none; border-color: var(--theme); }
    .newsletter-submit {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 600; font-size: 0.72rem;
      letter-spacing: 0.25em; text-transform: uppercase;
      color: var(--black);
      background: var(--theme);
      border: none;
      padding: 0 36px;
      cursor: pointer;
      transition: opacity 0.2s;
    }
    .newsletter-submit:hover { opacity: 0.9; }

    @media (max-width: 1024px) {
      .post-grid { grid-template-columns: repeat(2, 1fr); }
      .featured-card { grid-template-columns: 1fr; gap: 0; }
      .featured-content { padding: 36px 36px; }
    }

    @media (max-width: 860px) {
