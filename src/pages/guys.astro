<style is:global>

    .nav-item > a:hover { color: var(--white); }


    /* Right-aligned dropdowns for menu items near the right edge of screen */



    .nav-dropdown a:last-child { border-bottom: none; }
    .nav-dropdown a:hover { color: var(--white); background: rgba(255,255,255,0.03); padding-left: 30px; }
    .nav-dropdown a.ladies { border-left: 2px solid var(--pink); }
    .nav-dropdown a.guys { border-left: 2px solid var(--turquoise); }
    .nav-dropdown a.ladies:hover { color: var(--pink); }
    .nav-dropdown a.guys:hover { color: var(--turquoise); }

    .hero {
      padding: 140px 40px 80px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      top: 40%; left: 50%;
      transform: translate(-50%, -50%);
      width: 900px; height: 600px;
      background: radial-gradient(ellipse, rgba(0,212,184,0.08) 0%, transparent 65%);
      pointer-events: none;
    }

    .hero-content { position: relative; }

    .hero-eyebrow {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500;
      font-size: 0.7rem;
      letter-spacing: 0.38em;
      color: var(--theme);
      text-transform: uppercase;
      margin-bottom: 24px;
      opacity: 0;
      animation: fadeUp 0.8s ease forwards 0.2s;
    }

    .hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300;
      font-size: clamp(3rem, 8vw, 6rem);
      letter-spacing: 0.04em;
      color: var(--white);
      line-height: 0.95;
      margin-bottom: 8px;
      opacity: 0;
      animation: fadeUp 0.9s ease forwards 0.35s;
    }

    .hero-title em { font-style: italic; font-weight: 300; color: var(--theme); }

    .hero-sub {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-weight: 300;
      font-size: clamp(1.2rem, 2.6vw, 1.7rem);
      color: var(--silver);
      letter-spacing: 0.04em;
      margin-bottom: 28px;
      opacity: 0;
      animation: fadeUp 0.9s ease forwards 0.5s;
    }

    .hero-tagline {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500;
      font-size: 0.78rem;
      letter-spacing: 0.32em;
      color: var(--silver-mid);
      text-transform: uppercase;
      margin-bottom: 12px;
      opacity: 0;
      animation: fadeUp 0.9s ease forwards 0.65s;
    }

    .hero-count {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 600;
      font-size: clamp(3rem, 6vw, 5rem);
      color: var(--theme);
      line-height: 1;
      margin-top: 12px;
      opacity: 0;
      animation: fadeUp 0.9s ease forwards 0.8s;
      text-shadow: 0 0 60px rgba(0,212,184,0.4);
    }

    .hero-count-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 400;
      font-size: 0.72rem;
      letter-spacing: 0.4em;
      color: var(--silver-dark);
      text-transform: uppercase;
      margin-top: 8px;
      opacity: 0;
      animation: fadeUp 0.9s ease forwards 0.9s;
    }

    .agents-section { padding: 80px 40px 120px; max-width: 1400px; margin: 0 auto; }

    .agents-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }

    .agent-card {
      text-decoration: none;
      display: flex;
      flex-direction: column;
      background: var(--near-black);
      border: 1px solid rgba(255,255,255,0.05);
      transition: all 0.3s ease;
      overflow: hidden;
    }

    .agent-card:hover {
      border-color: var(--theme);
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(0,212,184,0.2);
    }

    .agent-photo-wrap {
      position: relative;
      aspect-ratio: 5/7;
      overflow: hidden;
      background: var(--charcoal);
    }

    .agent-photo {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease, filter 0.3s ease;
      filter: grayscale(15%);
    }

    .agent-card:hover .agent-photo { transform: scale(1.05); filter: grayscale(0%); }

    /* branded placeholder shown on every card until real agents are photographed.
       Theme-driven, so ladies picks up pink and guys picks up turquoise. */
    .agent-photo-fallback {
      display: flex;
      position: absolute; inset: 0;
      flex-direction: column; align-items: center; justify-content: center; gap: 10px;
      text-align: center; padding: 12px;
      background:
        radial-gradient(ellipse at center, rgba(var(--theme-rgb),0.10), transparent 70%),
        var(--near-black, #0c0c0c);
      border: 1px solid rgba(var(--theme-rgb),0.15);
    }
    .fallback-initials {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300; font-size: 3.2rem;
      color: rgba(var(--theme-rgb),0.85); line-height: 1;
      letter-spacing: 0.04em;
    }
    .fallback-note {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.62rem; letter-spacing: 0.26em; text-transform: uppercase;
      color: var(--silver-dark, #7a7a7a);
    }

    .agent-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(6,6,6,0.85) 0%, transparent 40%);
      display: flex;
      align-items: flex-end;
      justify-content: center;
      padding-bottom: 16px;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .agent-card:hover .agent-overlay { opacity: 1; }

    .agent-view {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 600;
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      color: var(--theme);
      text-transform: uppercase;
    }

    /* FLAG STRIP — full-bleed banner, fills the entire rectangle */
    .agent-flag-strip {
      position: relative;
      width: 100%;
      aspect-ratio: 3/2;  /* most flags are 3:2 — full flag visible, no cropping */
      overflow: hidden;
      background: #000;
      display: flex;
      align-items: center;
      justify-content: center;
    }


    /* LANGUAGE STRIP */
    .agent-lang-strip {
      padding: 14px 16px 8px;
      text-align: center;
    }

    .agent-lang-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 600;
      font-size: 0.95rem;
      letter-spacing: 0.18em;
      color: var(--theme);
      text-transform: uppercase;
    }

    /* NAME STRIP */
    .agent-name-strip {
      padding: 0 16px 18px;
      text-align: center;
    }

    .agent-name {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 500;
      font-size: 1.05rem;
      color: var(--white);
      line-height: 1.2;
    }

    .recruiting-note {
      max-width: 720px;
      margin: 0 auto 56px;
      padding: 24px 32px;
      border: 1px solid rgba(0,212,184,0.18);
      background: rgba(0,212,184,0.03);
      text-align: center;
      border-radius: 4px;
    }

    .recruiting-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 600;
      font-size: 0.66rem;
      letter-spacing: 0.32em;
      color: var(--theme);
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .recruiting-text {
      font-family: 'Barlow', sans-serif;
