---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Meet the Guys | 50 Male Agents in 50 Languages" description="Meet the Guys of Blackburn Realty Group — 50 male real estate agents fluent in 50 languages, serving every community in Florida.", theme="guys">

<section class="hero">
  <div class="hero-content">
    <p class="hero-eyebrow">Blackburn Realty Group</p>
    <h1 class="hero-title">Meet <em>The Guys.</em></h1>
    <p class="hero-sub">The men who built Florida's front door to the world.</p>
    <p class="hero-tagline">Every Language. Every Culture. Every Market.</p>
    <div class="hero-count">50</div>
    <p class="hero-count-label">Languages · 50 Countries · One Team</p>
  </div>
</section>

<section class="agents-section">
  <div class="recruiting-note">
    <p class="recruiting-label">Now Recruiting</p>
    <p class="recruiting-text">These positions are actively being filled by the most qualified bilingual male agents in Florida. If you speak one of these languages and want to join the most internationally diverse real estate team in the state — <a href="#">apply here</a>.</p>
  </div>

  <div class="agents-grid">
    <a href="#" class="agent-card">
      <div class="agent-photo-wrap">
        <div class="agent-photo-fallback">
          <span class="fallback-initials">DM</span>
          <span class="fallback-note">Photo coming soon</span>
        </div>
        <div class="agent-overlay">
          <span class="agent-view">View Profile →</span>
        </div>
      </div>
      <div class="agent-flag-strip">
        <img src="https://flagcdn.com/w640/es.png" alt="Spanish flag" class="agent-flag-img" loading="lazy" />
      </div>
      <div class="agent-lang-strip">
        <div class="agent-lang-name">Spanish</div>
      </div>
