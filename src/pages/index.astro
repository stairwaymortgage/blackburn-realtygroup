---
import BaseLayout from '../layouts/BaseLayout.astro';
import { IMAGES } from '../data/images';
---

<BaseLayout title="Blackburn Realty Group | Florida's International Real Estate Team" description="50 Languages. 1 Standard. 1 Team. Florida Welcomes You. A division of The Keyes Company.">

<div class="translate-toast" id="toast">Translating…</div>

<!-- ── NAV ── -->

<!-- ── HERO ── -->
<section class="hero" style={`--home-hero-img: url('${IMAGES.homeHero.src}')`}>

  <div class="hero-bg-layer"></div>

  <div class="hero-credentials">
    <p class="hero-cred-top">The Keyes Company &nbsp;·&nbsp; Est. 1926</p>
    <p class="hero-cred-main">#1 Independent Brokerage in Florida</p>
    <p class="hero-cred-stats">60+ Offices &nbsp;·&nbsp; 4,000+ Agents Statewide</p>
    <div class="hero-cred-rule"></div>
  </div>

  <h1 class="hero-title">Blackburn</h1>
  <span class="hero-title-sub">Realty Group</span>

  <div class="hero-tagline">
    <span class="tagline-line">50 Languages.</span>
    <span class="tagline-line dim">1 Standard. &nbsp; 1 Team.</span>
  </div>

  <p class="hero-welcome">Florida Welcomes You.</p>

  <div class="hero-divider"></div>
  <p class="hero-prompt">Select Your Language</p>

  <!-- 50 FLAGS — Official BRG List -->
