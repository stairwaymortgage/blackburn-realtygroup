      <div class="keyes-stat">
        <div class="keyes-stat-number">1926</div>
        <div class="keyes-stat-label">Est. by Ken Keyes</div>
      </div>
      <div class="keyes-stat">
        <div class="keyes-stat-number">60+</div>
        <div class="keyes-stat-label">Offices Across Florida</div>
      </div>
      <div class="keyes-stat">
        <div class="keyes-stat-number">4,000+</div>
        <div class="keyes-stat-label">Agents Statewide</div>
      </div>
