  <a href="#agents" class="mobile-sticky-btn">Find My Agent</a>
  <a href="#" class="mobile-sticky-btn">Get Pre-Approved</a>
  <a href="#" class="mobile-sticky-btn">Home Value</a>
</div>

<!-- ── GOOGLE TRANSLATE ── -->
<script is:inline>
  function googleTranslateElementInit() {
    new google.translate.TranslateElement({
      pageLanguage: 'en',
      includedLanguages: 'es,ht,pt,fr,ar,zh-CN,ru,tl,vi,de,uk,it,hi,pl,gu,te,iw,ko,ur,bn,th,yi,ml,ta,yo,ja,fa,km,so,pa,hy,nl,el,ro,tr,cs,hu,sr,hr,bg,sq,ne,sw,am,sv,id,ms,zh-TW',
      layout: google.translate.TranslateElement.InlineLayout.SIMPLE,
      autoDisplay: false
    }, 'google_translate_element');
  }
</script>
<script is:inline src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
<div id="google_translate_element" style="display:none;"></div>

<script is:inline>
  // ── TRANSLATE ──
  function translateTo(langCode, btn) {
    document.querySelectorAll('.flag-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const doTranslate = (c) => {
      c.value = langCode;
      c.dispatchEvent(new Event('change'));
      showToast(btn.querySelector('.flag-label').textContent);
    };
    const combo = document.querySelector('select.goog-te-combo');
    if (combo) doTranslate(combo);
    else setTimeout(() => { const c = document.querySelector('select.goog-te-combo'); if (c) doTranslate(c); }, 900);
  }

  function showToast(lang) {
    const t = document.getElementById('toast');
    t.textContent = 'Translating to ' + lang + '…';
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2800);
  }

  // ── NAV LOGO SCROLL REVEAL ──
  const navLogo = document.getElementById('navLogo');
  const heroTitle = document.querySelector('.hero-title');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) {
        navLogo.classList.add('visible');
      } else {
        navLogo.classList.remove('visible');
      }
    });
  }, { threshold: 0.1 });

  if (heroTitle) observer.observe(heroTitle);
</script>

</BaseLayout>

<style is:global>
/* ── NAV ── */

    /* Logo — hidden on load, fades in on scroll */

    .nav-logo.visible {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    /* ── DROPDOWN NAV ── */


    .nav-item > a:hover { color: var(--white); }

    /* Dropdown */

    /* Right-aligned dropdowns for menu items near the right edge of screen */
    .nav-item:nth-last-child(-n+3) 

    .nav-item:hover 


    .nav-dropdown a:last-child { border-bottom: none; }
    .nav-dropdown a:hover { color: var(--white); background: rgba(255,255,255,0.03); padding-left: 30px; }

    /* Pink underline for Meet the Ladies */
    .nav-dropdown a.ladies {
      border-left: 2px solid var(--pink);
    }

    /* Turquoise underline for Meet the Guys */
    .nav-dropdown a.guys {
      border-left: 2px solid var(--turquoise);
    }

    .nav-dropdown a.ladies:hover { color: var(--pink); }
    .nav-dropdown a.guys:hover { color: var(--turquoise); }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 120px 40px 80px;
      position: relative;
      overflow: hidden;
    }

    /* Dimmed Florida skyline behind the title — depth without cheapening */
    .hero-bg-layer {
      position: absolute; inset: 0; z-index: 0;
      background: var(--home-hero-img) center 30% / cover no-repeat;
      opacity: 0.22;
      -webkit-mask-image: radial-gradient(ellipse at center, rgba(0,0,0,0.95) 20%, transparent 78%);
      mask-image: radial-gradient(ellipse at center, rgba(0,0,0,0.95) 20%, transparent 78%);
    }
    .hero > *:not(.hero-bg-layer) { position: relative; z-index: 1; }

    /* Subtle vignette */
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center, transparent 40%, rgba(0,0,0,0.6) 100%);
      pointer-events: none;
    }

    /* Grain texture */
    .hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
      pointer-events: none;
      opacity: 0.5;
    }

    /* ── KEYES CREDENTIALS ── */
    .hero-credentials {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      margin-bottom: 48px;
      opacity: 0;
      animation: fadeUp 0.8s ease forwards 0.15s;
      position: relative;
      z-index: 1;
    }

    .hero-cred-top {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500;
      font-size: 0.85rem;
      letter-spacing: 0.32em;
      color: var(--silver-mid);
      text-transform: uppercase;
    }

    .hero-cred-main {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 1.05rem;
      letter-spacing: 0.22em;
      color: var(--white);
      text-transform: uppercase;
    }

    .hero-cred-stats {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500;
      font-size: 0.85rem;
      letter-spacing: 0.28em;
      color: var(--silver-mid);
      text-transform: uppercase;
    }

    /* Thin rule under credentials */
    .hero-cred-rule {
      width: 40px;
      height: 1px;
      background: rgba(255,255,255,0.15);
      margin: 4px auto 0;
    }

    /* ── HERO TITLE ── */
    .hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 600;
      font-size: clamp(4rem, 11vw, 9.5rem);
      letter-spacing: 0.05em;
      color: var(--white);
      text-transform: uppercase;
      line-height: 0.85;
      margin-bottom: 4px;
      opacity: 0;
      animation: fadeUp 0.9s ease forwards 0.3s;
      position: relative;
      z-index: 1;
    }

    .hero-title-sub {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-weight: 300;
      font-size: clamp(2.2rem, 6vw, 5.2rem);
