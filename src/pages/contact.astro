---
import BaseLayout from '../layouts/BaseLayout.astro';
import { IMAGES, SHOW_IMAGE_LABELS } from '../data/images';
---

<BaseLayout theme="contact" title="Contact Blackburn Realty Group" description="Contact Blackburn Realty Group. Talk to a bilingual real estate agent in your language. Buying, selling, financing, or exploring.">

<div class="breadcrumb">
  <div class="breadcrumb-inner">
    <a href="/">Home</a>
    <span class="breadcrumb-sep">/</span>
    <a href="/about/">About</a>
    <span class="breadcrumb-sep">/</span>
    <span>Contact Us</span>
  </div>
</div>

<section class="contact-hero" style={`--c-hero: url('${IMAGES.contactHero.src}')`}>
  <div class="contact-hero-veil"></div>
  <div class="contact-hero-inner reveal">
    <p class="page-eyebrow">Get in Touch</p>
    <h1 class="contact-hero-title">Talk to us <em>directly.</em></h1>
    <p class="contact-hero-sub">For agent questions, partnership inquiries, recruiting, or general communication &mdash; reach the Blackburn Realty Group leadership team below. In any language, within one business day.</p>
  </div>
  {SHOW_IMAGE_LABELS && !IMAGES.contactHero.team && (
    <div class="contact-hero-imglabel">Image · {IMAGES.contactHero.intent}</div>
  )}
</section>

<div class="contact-grid reveal">
  <div>
    <div class="contact-info-block">
      <div class="contact-info-label">General Inquiries</div>
      <div class="contact-info-value"><a href="mailto:info@blackburnrealtygroup.com">info@blackburnrealtygroup.com</a></div>
      <div class="contact-info-sub">Response within one business day, in any language.</div>
    </div>

    <div class="contact-info-block">
      <div class="contact-info-label">Phone</div>
      <div class="contact-info-value"><a href="tel:+13055550100">(305) 555-0100</a></div>
      <div class="contact-info-sub">Monday &ndash; Friday &middot; 8:00 AM &ndash; 8:00 PM EST<br/>Saturday &ndash; Sunday &middot; 9:00 AM &ndash; 6:00 PM EST</div>
    </div>

    <div class="contact-info-block">
      <div class="contact-info-label">Headquarters</div>
      <div class="contact-info-value">Fort Lauderdale, Florida</div>
      <div class="contact-info-sub">Operating statewide through the office network of The Keyes Company &mdash; 60+ locations across Florida.</div>
    </div>

    <div class="contact-info-block">
      <div class="contact-info-label">Recruiting &amp; Partnerships</div>
      <div class="contact-info-value"><a href="mailto:recruiting@blackburnrealtygroup.com">recruiting@blackburnrealtygroup.com</a></div>
      <div class="contact-info-sub">Are you a licensed Florida agent fluent in one of our 50 target languages? We are actively recruiting.</div>
    </div>

    <div class="contact-info-block">
      <div class="contact-info-label">Media &amp; Press</div>
      <div class="contact-info-value"><a href="mailto:press@blackburnrealtygroup.com">press@blackburnrealtygroup.com</a></div>
      <div class="contact-info-sub">For interviews, story inquiries, or speaking engagements.</div>
    </div>
  </div>

  <div class="form-card">
    <p class="form-card-eyebrow">Send a Message</p>
    <h2 class="form-card-title">How can we <em>help you?</em></h2>
    <p class="form-card-sub">Complete the form below and a member of our team will respond within one business day. For urgent matters, please call.</p>

    <div class="form-row">
      <div class="form-field">
        <label class="form-label">First Name</label>
        <input type="text" class="form-input" placeholder="Jane" />
      </div>
      <div class="form-field">
        <label class="form-label">Last Name</label>
        <input type="text" class="form-input" placeholder="Doe" />
      </div>
    </div>

    <div class="form-row">
      <div class="form-field">
        <label class="form-label">Email Address</label>
        <input type="email" class="form-input" placeholder="you@email.com" />
      </div>
      <div class="form-field">
        <label class="form-label">Phone</label>
        <input type="tel" class="form-input" placeholder="(305) 555-0123" />
      </div>
    </div>

    <div class="form-field">
      <label class="form-label">Preferred Language</label>
      <select class="form-select">
        <option>English</option>
        <option>Spanish / Espanol</option>
        <option>Portuguese / Portugues</option>
        <option>French / Francais</option>
        <option>Mandarin</option>
        <option>Russian</option>
        <option>Arabic</option>
        <option>Other / Specify in message</option>
      </select>
    </div>

    <div class="form-field">
      <label class="form-label">Reason for Contact</label>
      <select class="form-select">
        <option>General Inquiry</option>
        <option>Buying Property in Florida</option>
        <option>Selling Florida Property</option>
        <option>Mortgage / Financing Question</option>
        <option>Agent Recruiting Inquiry</option>
        <option>Partnership / Business Opportunity</option>
        <option>Media / Press Inquiry</option>
      </select>
    </div>

    <div class="form-field">
      <label class="form-label">Message</label>
      <textarea class="form-textarea" placeholder="Tell us how we can help..."></textarea>
    </div>

    <button class="btn-primary form-submit">Send Message</button>
  </div>
</div>

<section class="cta-strip">
  <div class="cta-strip-inner">
    <p class="cta-strip-eyebrow">Or Skip the Form</p>
    <h2 class="cta-strip-headline">Already know what you need? <em>Choose your path.</em></h2>
    <p class="cta-strip-body">Connect directly with a bilingual agent matched to your language and market.</p>
    <div class="cta-buttons">
      <a href="/ladies/" class="btn-primary">Find Your Agent</a>
      <a href="/tools/consultation/" class="btn-secondary">Book a Consultation</a>
    </div>
  </div>
</section>

<div class="mobile-sticky">
  <a href="/ladies/" class="mobile-sticky-btn">Find My Agent</a>
  <a href="/tools/preapproval/" class="mobile-sticky-btn">Get Pre-Approved</a>
  <a href="/tools/homevalue/" class="mobile-sticky-btn">Home Value</a>
</div>

</BaseLayout>

<style is:global>
    .nav-item > a:hover { color: var(--white); }
    .nav-item.active > 
    .nav-item.active-ladies > 
    .nav-item.active-guys > 
    
    .nav-item:nth-last-child(-n+3) 
    .nav-item:hover 
    .nav-dropdown a:last-child { border-bottom: none; }
    .nav-dropdown a:hover { color: var(--white); background: rgba(255,255,255,0.03); padding-left: 30px; }
    .nav-dropdown a.ladies { border-left: 2px solid var(--pink); }
    .nav-dropdown a.guys { border-left: 2px solid var(--turquoise); }
    .nav-dropdown a.ladies:hover { color: var(--pink); }
    .nav-dropdown a.guys:hover { color: var(--turquoise); }

    /* breadcrumb */

    .breadcrumb-inner a:hover { color: var(--theme); }

    /* page hero shared */
    .page-hero {
      padding: 60px 52px 80px;
      max-width: 1200px; margin: 0 auto;
      text-align: center;
    }
    .page-eyebrow {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.72rem;
      letter-spacing: 0.4em; color: var(--theme);
      text-transform: uppercase; margin-bottom: 24px;
    }
    .page-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300; font-size: clamp(2.8rem, 6vw, 5rem);
      letter-spacing: 0.02em; color: var(--white);
      line-height: 1; margin-bottom: 24px;
    }
    .page-title em { font-style: italic; color: var(--theme); }
    .page-sub {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-weight: 300;
      font-size: clamp(1.15rem, 2.2vw, 1.5rem);
      color: var(--silver); max-width: 720px; margin: 0 auto;
      line-height: 1.5;
    }

    /* sections */
    .section {
      padding: 80px 52px;
      max-width: 1100px; margin: 0 auto;
    }
    .section-wide { max-width: 1400px; }
    .section h2 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300; font-size: clamp(2rem, 4.2vw, 3.2rem);
      color: var(--white); line-height: 1.15; margin-bottom: 28px;
      letter-spacing: 0.01em;
    }
    .section h2 em { font-style: italic; color: var(--theme); }
    .section h3 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 500; font-size: 1.5rem;
      color: var(--white); margin-bottom: 14px;
    }
    .section-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.7rem;
      letter-spacing: 0.38em; color: var(--theme);
      text-transform: uppercase; margin-bottom: 20px;
    }
    .section p {
      font-family: 'Barlow', sans-serif;
      font-weight: 300; font-size: 1rem;
      line-height: 1.95; color: var(--silver-mid);
      margin-bottom: 24px;
    }
    .section p.lead {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-weight: 300;
      font-size: 1.4rem; color: var(--silver-light);
      line-height: 1.55; margin-bottom: 36px;
    }

    .section-rule {
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(255,255,255,0.08), transparent);
      max-width: 1100px; margin: 0 auto;
    }

    /* buttons */

    /* final cta strip */

    .cta-strip-headline em { font-style: italic; color: var(--theme); }

    /* footer */

    .footer-links a:hover { color: var(--silver-light); }

    /* mobile sticky */
    .mobile-sticky {
      display: none;
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 90;
      background: rgba(6,6,6,0.97);
      border-top: 1px solid rgba(255,255,255,0.08);
      padding: 12px 16px; gap: 8px;
      backdrop-filter: blur(12px);
    }
    .mobile-sticky-btn {
      flex: 1;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 600; font-size: 0.6rem;
      letter-spacing: 0.18em; text-transform: uppercase;
      text-align: center; text-decoration: none;
      padding: 12px 8px;
      border: 1px solid rgba(255,255,255,0.12);
      color: var(--silver-light);
      transition: all 0.2s;
    }
    .mobile-sticky-btn:hover { background: rgba(255,255,255,0.06); }

    /* mobile */
    @media (max-width: 860px) {

      .mobile-sticky { display: flex; }
      
      .page-hero { padding: 40px 22px 50px; }
      .section { padding: 60px 22px; }

    }

    .contact-grid {
      max-width: 1100px;
      margin: 0 auto;
      padding: 60px 52px;
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 80px;
      align-items: start;
    }
    .contact-info-block {
      margin-bottom: 36px;
      padding-bottom: 36px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .contact-info-block:last-child {
      border-bottom: none;
      margin-bottom: 0;
      padding-bottom: 0;
    }
    .contact-info-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500;
      font-size: 0.7rem;
      letter-spacing: 0.32em;
      color: var(--theme);
      text-transform: uppercase;
      margin-bottom: 14px;
    }
    .contact-info-value {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 400;
      font-size: 1.25rem;
      color: var(--white);
      line-height: 1.5;
      margin-bottom: 6px;
    }
    .contact-info-value a:hover { color: var(--theme); }
    .contact-info-sub {
      font-family: 'Barlow', sans-serif;
      font-weight: 300;
      font-size: 0.88rem;
      color: var(--silver-dark);
      line-height: 1.7;
    }

    /* Form */
    .form-card {
      background: var(--near-black);
      padding: 48px 44px;
      border: 1px solid rgba(255,255,255,0.06);
    }
    .form-card-eyebrow {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500;
      font-size: 0.7rem;
      letter-spacing: 0.32em;
      color: var(--theme);
      text-transform: uppercase;
      margin-bottom: 14px;
    }
    .form-card-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300;
      font-size: 2rem;
      color: var(--white);
      line-height: 1.15;
      margin-bottom: 14px;
    }
    .form-card-title em { font-style: italic; color: var(--theme); }
    .form-card-sub {
      font-family: 'Barlow', sans-serif;
      font-weight: 300;
      font-size: 0.92rem;
      color: var(--silver-dark);
      line-height: 1.7;
      margin-bottom: 32px;
    }
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 16px;
    }
    .form-field { margin-bottom: 16px; }
    .form-label {
      display: block;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500;
      font-size: 0.66rem;
      letter-spacing: 0.22em;
      color: var(--silver-dark);
      text-transform: uppercase;
      margin-bottom: 8px;
    }
    .form-input, .form-select, .form-textare
    .form-input:focus, .form-select:focus, .form-textarea:focus {
      outline: none;
      border-color: var(--theme);
      background: rgba(255,255,255,0.02);
    }
    .form-submit {
      width: 100%;
      margin-top: 20px;
      padding: 18px;
      cursor: pointer;
      border: none;
    }

    @media (max-width: 860px) {
      .contact-grid { grid-template-columns: 1fr; gap: 48px; padding: 40px 22px; }
      .form-card { padding: 36px 24px; }
      .form-row { grid-template-columns: 1fr; }
      .contact-hero { min-height: 60vh; padding: 100px 22px 60px; background-attachment: scroll; }
    }

    /* ── ARRIVAL HERO (coral threshold) ── */
    .contact-hero {
      position: relative;
      min-height: 66vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 130px 32px 90px;
      overflow: hidden;
      background: var(--c-hero) center 35% / cover no-repeat;
    }
    .contact-hero-veil {
      position: absolute; inset: 0;
      background:
        linear-gradient(180deg, rgba(6,6,6,0.62) 0%, rgba(6,6,6,0.8) 60%, var(--black) 100%),
        radial-gradient(ellipse at 50% 120%, rgba(var(--theme-rgb),0.26), transparent 62%);
    }
    .contact-hero-inner { position: relative; max-width: 780px; }
    .contact-hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300; font-size: clamp(2.8rem, 6.5vw, 5.2rem);
      line-height: 1; color: var(--white); margin-bottom: 26px;
    }
    .contact-hero-title em { font-style: italic; color: var(--theme); }
    .contact-hero-sub {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-weight: 300;
      font-size: clamp(1.1rem, 2.2vw, 1.5rem);
      color: var(--silver); line-height: 1.55; max-width: 640px; margin: 0 auto;
    }
    .contact-hero-imglabel {
      position: absolute; left: 0; right: 0; bottom: 0; z-index: 2;
      padding: 8px 14px;
      background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
      font-family: 'Barlow', sans-serif; font-size: 0.7rem;
      color: rgba(255,255,255,0.72); text-align: left;
    }

    /* warm the contact info blocks on hover */
    .contact-info-block {
      transition: border-color 0.35s, background 0.35s, transform 0.35s;
      border-left: 2px solid transparent; padding-left: 18px;
    }
    .contact-info-block:hover {
      border-left-color: var(--theme);
      background: rgba(var(--theme-rgb), 0.04);
      transform: translateX(4px);
    }

    /* ── SCROLL REVEAL ── */
    .reveal {
      opacity: 0; transform: translateY(26px);
      transition: opacity 0.9s cubic-bezier(0.2,0.7,0.2,1), transform 0.9s cubic-bezier(0.2,0.7,0.2,1);
    }
    .reveal.is-in { opacity: 1; transform: none; }
    @media (prefers-reduced-motion: reduce) {
      .reveal { opacity: 1; transform: none; transition: none; }
    }
</style>

<script is:inline>
  (function () {
    var els = document.querySelectorAll('.reveal');
    if (!('IntersectionObserver' in window)) {
      els.forEach(function (e) { e.classList.add('is-in'); });
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) { entry.target.classList.add('is-in'); io.unobserve(entry.target); }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -6% 0px' });
    els.forEach(function (e) { io.observe(e); });
  })();
</script>
