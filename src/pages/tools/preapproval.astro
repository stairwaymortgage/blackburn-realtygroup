---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { IMAGES, SHOW_IMAGE_LABELS } from '../../data/images';
---

<BaseLayout theme="tools" title="Get Pre-Approved | Blackburn Realty Group" description="Get pre-approved for a Florida mortgage through Stairway Mortgage. Multilingual processing.">

<div class="breadcrumb">
  <div class="breadcrumb-inner">
    <a href="/">Home</a>
    <span class="breadcrumb-sep">/</span>
    <span>Tools</span>
    <span class="breadcrumb-sep">/</span>
    <span>Tool / Pre-Approval</span>
  </div>
</div>

<section class="tool-hero reveal" style={`--tool-hero-img: url('${IMAGES.toolPreapproval.src}')`}>
  <p class="tool-hero-eyebrow">Tool / Pre-Approval</p>
  <h1 class="tool-hero-title">Get <em>pre-approved</em> in 24 hours.</h1>
  <p class="tool-hero-sub">Conventional, DSCR, FHA, VA, Jumbo, or Foreign National financing — processed in your language through Stairway Mortgage, our trusted partner.</p>
  {SHOW_IMAGE_LABELS && !IMAGES.toolPreapproval.team && (
    <div class="tool-hero-imglabel">Image · {IMAGES.toolPreapproval.intent}</div>
  )}
</section>

<div class="promise-strip">
    <div class="promise-cell">
      <div class="promise-num">01</div>
      <div class="promise-label">Fast</div>
      <div class="promise-text">Most applications return a pre-approval letter within 24 hours of submission.</div>
    </div>
    <div class="promise-cell">
      <div class="promise-num">02</div>
      <div class="promise-label">Multilingual</div>
      <div class="promise-text">Loan officers fluent in your language guide you through every form and question.</div>
    </div>
    <div class="promise-cell">
      <div class="promise-num">03</div>
      <div class="promise-label">No Obligation</div>
      <div class="promise-text">A pre-approval does not commit you to anything. It is your leverage in the market.</div>
    </div>
</div>

<section class="tool-form-section">
  <div class="tool-form-left">
    <h2>Start your <em>application.</em></h2>
    <p>Complete this short form and a Stairway Mortgage loan officer will reach out within one business day in your preferred language. You will receive a pre-approval letter you can use with any property, anywhere in Florida.</p>

    <div class="what-happens">
      <p class="what-happens-label">What happens next</p>
      <div class="step-list"><div class="step-item"><div class="step-num">01</div><div class="step-text">We match you with a loan officer fluent in your language</div></div><div class="step-item"><div class="step-num">02</div><div class="step-text">You receive an introductory call within 24 hours</div></div><div class="step-item"><div class="step-num">03</div><div class="step-text">You complete the full application securely online</div></div><div class="step-item"><div class="step-num">04</div><div class="step-text">Pre-approval letter delivered within 24-72 hours</div></div><div class="step-item"><div class="step-num">05</div><div class="step-text">Use your pre-approval to make offers with confidence</div></div>
      </div>
    </div>
  </div>

  <div class="form-card">
    <div class="form-row">
      <div class="form-field">
        <label class="form-label">First Name</label>
        <input type="text" class="form-input" placeholder="Jane" />
      </div>
      <div class="form-field">
        <label class="form-label">Last Name</label>
        <input type="text" class="form-input" placeholder="Doe" />
      </div>
    </div>

    <div class="form-row">
      <div class="form-field">
        <label class="form-label">Email Address</label>
        <input type="email" class="form-input" placeholder="you@email.com" />
      </div>
      <div class="form-field">
        <label class="form-label">Phone</label>
        <input type="tel" class="form-input" placeholder="(305) 555-0123" />
      </div>
    </div>

    <div class="form-field">
      <label class="form-label">Preferred Language</label>
      <select class="form-select">
        <option>English</option>
        <option>Spanish / Espanol</option>
        <option>Portuguese / Portugues</option>
        <option>French / Francais</option>
        <option>Mandarin</option>
        <option>Russian</option>
        <option>Arabic</option>
        <option>Other / Specify in message</option>
      </select>
    </div>

    <div class="form-field"><label class="form-label">Loan Type Interest</label><select class="form-select"><option>Not sure yet — please advise</option><option>Conventional 30-year</option><option>Conventional 15-year</option><option>FHA</option><option>VA (Veteran)</option><option>Jumbo</option><option>DSCR (Investor)</option><option>Foreign National</option></select></div><div class="form-field"><label class="form-label">Estimated Purchase Price</label><select class="form-select"><option>Under $200,000</option><option>$200,000 - $400,000</option><option>$400,000 - $600,000</option><option>$600,000 - $1M</option><option>$1M - $2M</option><option>$2M - $5M</option><option>Over $5M</option></select></div><div class="form-field"><label class="form-label">Estimated Down Payment %</label><select class="form-select"><option>3-5%</option><option>10%</option><option>15-20%</option><option>25-30%</option><option>30%+</option><option>Cash buyer (no loan needed)</option></select></div><div class="form-field"><label class="form-label">Where in Florida are you buying?</label><input type="text" class="form-input" placeholder="Miami, Orlando, Tampa, etc." /></div>

    <button class="btn-primary form-submit">Start My Pre-Approval</button>
    <p class="form-privacy">Your info stays private &middot; Used only for this request &middot; No spam, ever</p>
  </div>
</section>

<section class="testimonial-section">
  <p class="testimonial-eyebrow">From Recent Clients</p>
  <p class="testimonial-quote">They processed our Foreign National loan in three weeks — start to finish, in Spanish, with zero confusion. Other lenders had told us six months. Blackburn and Stairway delivered.</p>
  <p class="testimonial-attr">M. and L. Hernandez &middot; Buyers from Mexico City &middot; $1.4M Brickell Condo</p>
</section>

<section class="cta-strip">
  <div class="cta-strip-inner">
    <p class="cta-strip-eyebrow">Prefer to Talk Directly?</p>
    <h2 class="cta-strip-headline">Skip the form. <em>Find your agent.</em></h2>
    <p class="cta-strip-body">If you would rather pick an agent who speaks your language and contact them directly, browse our team.</p>
    <div class="cta-buttons">
      <a href="/ladies/" class="btn-primary">Meet the Ladies</a>
      <a href="/guys/" class="btn-secondary">Meet the Guys</a>
    </div>
  </div>
</section>

<div class="mobile-sticky">
  <a href="/ladies/" class="mobile-sticky-btn">Find My Agent</a>
  <a href="/tools/preapproval/" class="mobile-sticky-btn">Get Pre-Approved</a>
  <a href="/tools/homevalue/" class="mobile-sticky-btn">Home Value</a>
</div>


<script is:inline>
  (function () {
    var els = document.querySelectorAll('.reveal');
    if (!('IntersectionObserver' in window)) { els.forEach(function (e) { e.classList.add('is-in'); }); return; }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) { entry.target.classList.add('is-in'); io.unobserve(entry.target); }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -6% 0px' });
    els.forEach(function (e) { io.observe(e); });
  })();
</script>

</BaseLayout>

<style is:global>
    .nav-item > a:hover { color: var(--white); }
    
    .nav-dropdown a:last-child { border-bottom: none; }
    .nav-dropdown a:hover { color: var(--white); background: rgba(255,255,255,0.03); padding-left: 30px; }
    .nav-dropdown a.ladies { border-left: 2px solid var(--pink); }
    .nav-dropdown a.guys { border-left: 2px solid var(--turquoise); }
    .nav-dropdown a.ladies:hover { color: var(--pink); }
    .nav-dropdown a.guys:hover { color: var(--turquoise); }

    /* breadcrumb */

    .breadcrumb-inner a:hover { color: var(--theme); }

    /* page hero shared */
    .page-hero {
      padding: 60px 52px 80px;
      max-width: 1200px; margin: 0 auto;
      text-align: center;
    }
    .page-eyebrow {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.72rem;
      letter-spacing: 0.4em; color: var(--theme);
      text-transform: uppercase; margin-bottom: 24px;
    }
    .page-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300; font-size: clamp(2.8rem, 6vw, 5rem);
      letter-spacing: 0.02em; color: var(--white);
      line-height: 1; margin-bottom: 24px;
    }
    .page-title em { font-style: italic; color: var(--theme); }
    .page-sub {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-weight: 300;
      font-size: clamp(1.15rem, 2.2vw, 1.5rem);
      color: var(--silver); max-width: 720px; margin: 0 auto;
      line-height: 1.5;
    }

    /* sections */
    .section {
      padding: 80px 52px;
      max-width: 1100px; margin: 0 auto;
    }
    .section-wide { max-width: 1400px; }
    .section h2 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300; font-size: clamp(2rem, 4.2vw, 3.2rem);
      color: var(--white); line-height: 1.15; margin-bottom: 28px;
      letter-spacing: 0.01em;
    }
    .section h2 em { font-style: italic; color: var(--theme); }
    .section h3 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 500; font-size: 1.5rem;
      color: var(--white); margin-bottom: 14px;
    }
    .section-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.7rem;
      letter-spacing: 0.38em; color: var(--theme);
      text-transform: uppercase; margin-bottom: 20px;
    }
    .section p {
      font-family: 'Barlow', sans-serif;
      font-weight: 300; font-size: 1rem;
      line-height: 1.95; color: var(--silver-mid);
      margin-bottom: 24px;
    }
    .section p.lead {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-weight: 300;
      font-size: 1.4rem; color: var(--silver-light);
      line-height: 1.55; margin-bottom: 36px;
    }

    .section-rule {
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(255,255,255,0.08), transparent);
      max-width: 1100px; margin: 0 auto;
    }

    /* buttons */

    /* final cta strip */

    .cta-strip-headline em { font-style: italic; color: var(--theme); }

    /* footer */

    .footer-links a:hover { color: var(--silver-light); }

    /* mobile sticky */
    .mobile-sticky {
      display: none;
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 90;
      background: rgba(6,6,6,0.97);
      border-top: 1px solid rgba(255,255,255,0.08);
      padding: 12px 16px; gap: 8px;
      backdrop-filter: blur(12px);
    }
    .mobile-sticky-btn {
      flex: 1;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 600; font-size: 0.6rem;
      letter-spacing: 0.18em; text-transform: uppercase;
      text-align: center; text-decoration: none;
      padding: 12px 8px;
      border: 1px solid rgba(255,255,255,0.12);
      color: var(--silver-light);
      transition: all 0.2s;
    }
    .mobile-sticky-btn:hover { background: rgba(255,255,255,0.06); }

    /* mobile */
    @media (max-width: 860px) {

      .mobile-sticky { display: flex; }
      
      .page-hero { padding: 40px 22px 50px; }
      .section { padding: 60px 22px; }

    }

    .tool-hero {
      padding: 100px 52px 60px;
      max-width: 1200px;
      margin: 0 auto;
      text-align: center;
    }
    .tool-hero-eyebrow {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.72rem;
      letter-spacing: 0.4em; color: var(--theme);
      text-transform: uppercase; margin-bottom: 24px;
    }
    .tool-hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300; font-size: clamp(2.6rem, 5.5vw, 4.5rem);
      letter-spacing: 0.01em; color: var(--white);
      line-height: 1.05; margin-bottom: 24px;
    }
    .tool-hero-title em { font-style: italic; color: var(--theme); }
    .tool-hero-sub {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-weight: 300;
      font-size: 1.3rem; color: var(--silver);
      max-width: 720px; margin: 0 auto;
      line-height: 1.5;
    }

    .promise-strip {
      max-width: 1100px;
      margin: 0 auto;
      padding: 40px 52px 60px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
      border-top: 1px solid rgba(255,255,255,0.05);
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .promise-cell {
      padding: 32px 24px;
      text-align: center;
      border-right: 1px solid rgba(255,255,255,0.08);
    }
    .promise-cell:last-child { border-right: none; }
    .promise-num {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300; font-size: 2.4rem;
      color: var(--theme); line-height: 1; margin-bottom: 12px;
    }
    .promise-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.66rem;
      letter-spacing: 0.28em; color: var(--silver-mid);
      text-transform: uppercase; margin-bottom: 8px;
    }
    .promise-text {
      font-family: 'Barlow', sans-serif;
      font-weight: 300; font-size: 0.85rem;
      color: var(--silver-dark); line-height: 1.6;
    }

    .tool-form-section {
      max-width: 1100px;
      margin: 0 auto;
      padding: 80px 52px;
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 80px;
    }
    .tool-form-left h2 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300; font-size: clamp(2rem, 4vw, 2.8rem);
      color: var(--white); line-height: 1.15;
      margin-bottom: 24px;
    }
    .tool-form-left h2 em { font-style: italic; color: var(--theme); }
    .tool-form-left p {
      font-family: 'Barlow', sans-serif;
      font-weight: 300; font-size: 1rem;
      color: var(--silver-mid); line-height: 1.9;
      margin-bottom: 22px;
    }
    .what-happens {
      margin-top: 36px;
      padding-top: 30px;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .what-happens-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 600; font-size: 0.66rem;
      letter-spacing: 0.3em; color: var(--theme);
      text-transform: uppercase; margin-bottom: 18px;
    }
    .step-list { display: flex; flex-direction: column; gap: 18px; }
    .step-item {
      display: grid;
      grid-template-columns: 32px 1fr;
      gap: 14px;
      align-items: start;
    }
    .step-num {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 500; font-size: 1.1rem;
      color: var(--theme); line-height: 1.3;
    }
    .step-text {
      font-family: 'Barlow', sans-serif;
      font-weight: 300; font-size: 0.92rem;
      color: var(--silver-mid); line-height: 1.6;
    }

    .form-card {
      background: var(--near-black);
      padding: 48px 44px;
      border: 1px solid rgba(255,255,255,0.06);
    }
    .form-card-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300; font-size: 1.6rem;
      color: var(--white); line-height: 1.2;
      margin-bottom: 14px;
    }
    .form-card-title em { font-style: italic; color: var(--theme); }
    .form-card-sub {
      font-family: 'Barlow', sans-serif;
      font-weight: 300; font-size: 0.88rem;
      color: var(--silver-dark); line-height: 1.7;
      margin-bottom: 32px;
    }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
    .form-field { margin-bottom: 16px; }
    .form-label {
      display: block;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.66rem;
      letter-spacing: 0.22em; color: var(--silver-dark);
      text-transform: uppercase; margin-bottom: 8px;
    }
    .form-input, .form-select, .form-textarea {
      width: 100%;
      padding: 14px 16px;
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(255,255,255,0.12);
      color: var(--white);
      font-family: 'Barlow', sans-serif;
      font-weight: 300;
      font-size: 16px; /* >=16px prevents iOS zoom-on-focus */
      transition: border-color 0.2s, background 0.2s;
    }
    .form-textarea { min-height: 130px; resize: vertical; }
    .form-select { -webkit-appearance: none; appearance: none; }
    .form-input:focus, .form-select:focus, .form-textarea:focus {
      outline: none; border-color: var(--theme);
      background: rgba(255,255,255,0.02);
    }
    .form-submit { width: 100%; margin-top: 20px; padding: 18px; cursor: pointer; border: none; }
    .form-privacy {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 400; font-size: 0.62rem;
      letter-spacing: 0.18em; color: var(--silver-dark);
      text-transform: uppercase; text-align: center;
      margin-top: 16px;
    }

    .testimonial-section {
      max-width: 1000px;
      margin: 0 auto;
      padding: 60px 52px;
      text-align: center;
    }
    .testimonial-eyebrow {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.66rem;
      letter-spacing: 0.32em; color: var(--theme);
      text-transform: uppercase; margin-bottom: 18px;
    }
    .testimonial-quote {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-weight: 300;
      font-size: clamp(1.4rem, 2.8vw, 1.8rem);
      color: var(--white); line-height: 1.45;
      max-width: 800px; margin: 0 auto 24px;
    }
    .testimonial-attr {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.7rem;
      letter-spacing: 0.28em; color: var(--silver-dark);
      text-transform: uppercase;
    }

    @media (max-width: 1024px) {
      .tool-form-section { grid-template-columns: 1fr; gap: 48px; }
      .promise-strip { grid-template-columns: 1fr; gap: 0; }
      .promise-cell { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.08); }
      .promise-cell:last-child { border-bottom: none; }
    }

    @media (max-width: 860px) {
      .tool-hero { padding: 90px 22px 40px; }
      .promise-strip { padding: 30px 22px 40px; }
      .tool-form-section { padding: 60px 22px; }
      .form-card { padding: 36px 24px; }
      .form-row { grid-template-columns: 1fr; }
      .testimonial-section { padding: 50px 22px; }
    }

    /* ── TOOLS ROOM: image hero + reveal (sky-cyan concierge) ── */
    .tool-hero {
      position: relative;
      max-width: none;
      padding: 130px 32px 90px;
      text-align: center;
      overflow: hidden;
      background: var(--tool-hero-img) center 38% / cover no-repeat;
    }
    .tool-hero::before {
      content: ''; position: absolute; inset: 0;
      background:
        linear-gradient(180deg, rgba(6,6,6,0.6) 0%, rgba(6,6,6,0.82) 62%, var(--black) 100%),
        radial-gradient(ellipse at 50% 120%, rgba(var(--theme-rgb),0.22), transparent 62%);
    }
    .tool-hero > * { position: relative; z-index: 1; }
    .tool-hero-imglabel {
      position: absolute; left: 0; right: 0; bottom: 0; z-index: 2;
      padding: 8px 14px; text-align: left;
      background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
      font-family: 'Barlow', sans-serif; font-size: 0.7rem; color: rgba(255,255,255,0.72);
    }
    .reveal {
      opacity: 0; transform: translateY(26px);
      transition: opacity 0.9s cubic-bezier(0.2,0.7,0.2,1), transform 0.9s cubic-bezier(0.2,0.7,0.2,1);
    }
    .reveal.is-in { opacity: 1; transform: none; }
    @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; transition: none; } }

    /* ═══ Responsive polish — appended last so it wins the cascade ═══ */
    @media (max-width: 1024px) {
      .tool-form-section { grid-template-columns: 1fr; gap: 48px; }
      .promise-strip { grid-template-columns: 1fr; }
      .promise-cell { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.08); }
      .promise-cell:last-child { border-bottom: none; }
    }
    @media (max-width: 860px) {
      .tool-hero { padding: 104px 22px 52px; }
      .promise-strip { padding: 30px 22px 40px; }
      .promise-cell { padding: 28px 18px; }
      .tool-form-section { padding: 56px 22px; gap: 40px; }
      .form-card { padding: 32px 22px; }
      .form-row { grid-template-columns: 1fr; }
      .testimonial-section { padding: 50px 22px; }
      .section { padding: 56px 22px; }
      .page-hero { padding: 100px 22px 40px; }
    }
    @media (max-width: 600px) {
      .tool-hero { padding: 98px 20px 46px; }
      .tool-hero-sub { font-size: 1.15rem; }
      .form-submit { width: 100%; }
    }

</style>
