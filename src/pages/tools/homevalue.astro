---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { IMAGES, SHOW_IMAGE_LABELS } from '../../data/images';
---

<BaseLayout theme="tools" title="Free Home Value Report | Blackburn Realty Group" description="Free Florida property valuation prepared by a licensed agent. Real numbers from real recent sales.">

<div class="breadcrumb">
  <div class="breadcrumb-inner">
    <a href="/">Home</a>
    <span class="breadcrumb-sep">/</span>
    <span>Tools</span>
    <span class="breadcrumb-sep">/</span>
    <span>Tool / Home Valuation</span>
  </div>
</div>

<section class="tool-hero reveal" style={`--tool-hero-img: url('${IMAGES.toolHomevalue.src}')`}>
  <p class="tool-hero-eyebrow">Tool / Home Valuation</p>
  <h1 class="tool-hero-title">What is your <em>Florida home</em> really worth?</h1>
  <p class="tool-hero-sub">Get a free Comparative Market Analysis prepared by a licensed agent. Real numbers from real recent sales. No automated estimates. No obligation.</p>
  {SHOW_IMAGE_LABELS && !IMAGES.toolHomevalue.team && (
    <div class="tool-hero-imglabel">Image · {IMAGES.toolHomevalue.intent}</div>
  )}
</section>

<div class="promise-strip">
    <div class="promise-cell">
      <div class="promise-num">01</div>
      <div class="promise-label">Real Analysis</div>
      <div class="promise-text">A licensed agent reviews your home and the most relevant recent comparables. Not an algorithm.</div>
    </div>
    <div class="promise-cell">
      <div class="promise-num">02</div>
      <div class="promise-label">Free Report</div>
      <div class="promise-text">Detailed PDF report delivered within 3 business days, in your language.</div>
    </div>
    <div class="promise-cell">
      <div class="promise-num">03</div>
      <div class="promise-label">No Pressure</div>
      <div class="promise-text">You receive the report. We follow up once to see if you have questions. That's it.</div>
    </div>
</div>

<section class="tool-form-section">
  <div class="tool-form-left">
    <h2>Request your <em>free report.</em></h2>
    <p>Tell us about your property. A bilingual agent specializing in your area will prepare a customized Comparative Market Analysis and deliver it to your inbox.</p>

    <div class="what-happens">
      <p class="what-happens-label">What happens next</p>
      <div class="step-list"><div class="step-item"><div class="step-num">01</div><div class="step-text">An agent specializing in your area is matched to your request</div></div><div class="step-item"><div class="step-num">02</div><div class="step-text">They research your property and pull recent comparable sales</div></div><div class="step-item"><div class="step-num">03</div><div class="step-text">A customized CMA is prepared and reviewed</div></div><div class="step-item"><div class="step-num">04</div><div class="step-text">Full PDF report delivered to your email within 3 business days</div></div><div class="step-item"><div class="step-num">05</div><div class="step-text">One follow-up to answer questions — no sales pressure</div></div>
      </div>
    </div>
  </div>

  <div class="form-card">
    <div class="form-row">
      <div class="form-field">
        <label class="form-label">First Name</label>
        <input type="text" class="form-input" placeholder="Jane" />
      </div>
      <div class="form-field">
        <label class="form-label">Last Name</label>
        <input type="text" class="form-input" placeholder="Doe" />
      </div>
    </div>

    <div class="form-row">
      <div class="form-field">
        <label class="form-label">Email Address</label>
        <input type="email" class="form-input" placeholder="you@email.com" />
      </div>
      <div class="form-field">
        <label class="form-label">Phone</label>
        <input type="tel" class="form-input" placeholder="(305) 555-0123" />
      </div>
    </div>

    <div class="form-field">
      <label class="form-label">Preferred Language</label>
      <select class="form-select">
        <option>English</option>
        <option>Spanish / Espanol</option>
        <option>Portuguese / Portugues</option>
        <option>French / Francais</option>
        <option>Mandarin</option>
        <option>Russian</option>
        <option>Arabic</option>
        <option>Other / Specify in message</option>
      </select>
    </div>

    <div class="form-field"><label class="form-label">Property Address</label><input type="text" class="form-input" placeholder="123 Ocean Drive, Miami Beach, FL" /></div><div class="form-field"><label class="form-label">Property Type</label><select class="form-select"><option>Single-family home</option><option>Condominium</option><option>Townhouse</option><option>Multi-family</option><option>Vacant land</option><option>Other</option></select></div><div class="form-field"><label class="form-label">Approximate Square Footage</label><input type="text" class="form-input" placeholder="2,400 sqft" /></div><div class="form-field"><label class="form-label">Bedrooms / Bathrooms</label><input type="text" class="form-input" placeholder="3 bed / 2.5 bath" /></div><div class="form-field"><label class="form-label">When are you considering selling?</label><select class="form-select"><option>Within 30 days</option><option>Within 3 months</option><option>Within 6 months</option><option>Within 1 year</option><option>Just curious / Not sure yet</option></select></div><div class="form-field"><label class="form-label">Anything special about your home?</label><textarea class="form-textarea" placeholder="Recent renovations, waterfront, pool, lot size, views, etc."></textarea></div>

    <button class="btn-primary form-submit">Get My Free Report</button>
    <p class="form-privacy">Your info stays private &middot; Used only for this request &middot; No spam, ever</p>
  </div>
</section>

<section class="testimonial-section">
  <p class="testimonial-eyebrow">From Recent Clients</p>
  <p class="testimonial-quote">The report was honest. They told me my home was worth $80K less than I thought — and explained exactly why. I appreciated the truth more than I would have appreciated a flattering lie.</p>
  <p class="testimonial-attr">D. Oliveira &middot; Aventura Homeowner &middot; Listed and sold in 31 days</p>
</section>

<section class="cta-strip">
  <div class="cta-strip-inner">
    <p class="cta-strip-eyebrow">Prefer to Talk Directly?</p>
    <h2 class="cta-strip-headline">Skip the form. <em>Find your agent.</em></h2>
    <p class="cta-strip-body">If you would rather pick an agent who speaks your language and contact them directly, browse our team.</p>
    <div class="cta-buttons">
      <a href="/ladies/" class="btn-primary">Meet the Ladies</a>
      <a href="/guys/" class="btn-secondary">Meet the Guys</a>
    </div>
  </div>
</section>

<div class="mobile-sticky">
  <a href="/ladies/" class="mobile-sticky-btn">Find My Agent</a>
  <a href="/tools/preapproval/" class="mobile-sticky-btn">Get Pre-Approved</a>
  <a href="/tools/homevalue/" class="mobile-sticky-btn">Home Value</a>
</div>


<script is:inline>
  (function () {
    var els = document.querySelectorAll('.reveal');
    if (!('IntersectionObserver' in window)) { els.forEach(function (e) { e.classList.add('is-in'); }); return; }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) { entry.target.classList.add('is-in'); io.unobserve(entry.target); }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -6% 0px' });
    els.forEach(function (e) { io.observe(e); });
  })();
</script>

</BaseLayout>

<style is:global>
    .nav-item > a:hover { color: var(--white); }
    .nav-item.active > 
    .nav-item.active-ladies > 
    .nav-item.active-guys > 
    
    .nav-item:nth-last-child(-n+3) 
    .nav-item:hover 
    .nav-dropdown a:last-child { border-bottom: none; }
    .nav-dropdown a:hover { color: var(--white); background: rgba(255,255,255,0.03); padding-left: 30px; }
    .nav-dropdown a.ladies { border-left: 2px solid var(--pink); }
    .nav-dropdown a.guys { border-left: 2px solid var(--turquoise); }
    .nav-dropdown a.ladies:hover { color: var(--pink); }
    .nav-dropdown a.guys:hover { color: var(--turquoise); }

    /* breadcrumb */

    .breadcrumb-inner a:hover { color: var(--theme); }

    /* page hero shared */
    .page-hero {
      padding: 60px 52px 80px;
      max-width: 1200px; margin: 0 auto;
      text-align: center;
    }
    .page-eyebrow {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.72rem;
      letter-spacing: 0.4em; color: var(--theme);
      text-transform: uppercase; margin-bottom: 24px;
    }
    .page-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300; font-size: clamp(2.8rem, 6vw, 5rem);
      letter-spacing: 0.02em; color: var(--white);
      line-height: 1; margin-bottom: 24px;
    }
    .page-title em { font-style: italic; color: var(--theme); }
    .page-sub {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-weight: 300;
      font-size: clamp(1.15rem, 2.2vw, 1.5rem);
      color: var(--silver); max-width: 720px; margin: 0 auto;
      line-height: 1.5;
    }

    /* sections */
    .section {
      padding: 80px 52px;
      max-width: 1100px; margin: 0 auto;
    }
    .section-wide { max-width: 1400px; }
    .section h2 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300; font-size: clamp(2rem, 4.2vw, 3.2rem);
      color: var(--white); line-height: 1.15; margin-bottom: 28px;
      letter-spacing: 0.01em;
    }
    .section h2 em { font-style: italic; color: var(--theme); }
    .section h3 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 500; font-size: 1.5rem;
      color: var(--white); margin-bottom: 14px;
    }
    .section-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.7rem;
      letter-spacing: 0.38em; color: var(--theme);
      text-transform: uppercase; margin-bottom: 20px;
    }
    .section p {
      font-family: 'Barlow', sans-serif;
      font-weight: 300; font-size: 1rem;
      line-height: 1.95; color: var(--silver-mid);
      margin-bottom: 24px;
    }
    .section p.lead {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-weight: 300;
      font-size: 1.4rem; color: var(--silver-light);
      line-height: 1.55; margin-bottom: 36px;
    }

    .section-rule {
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(255,255,255,0.08), transparent);
      max-width: 1100px; margin: 0 auto;
    }

    /* buttons */

    /* final cta strip */

    .cta-strip-headline em { font-style: italic; color: var(--theme); }

    /* footer */

    .footer-links a:hover { color: var(--silver-light); }

    /* mobile sticky */
    .mobile-sticky {
      display: none;
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 90;
      background: rgba(6,6,6,0.97);
      border-top: 1px solid rgba(255,255,255,0.08);
      padding: 12px 16px; gap: 8px;
      backdrop-filter: blur(12px);
    }
    .mobile-sticky-btn {
      flex: 1;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 600; font-size: 0.6rem;
      letter-spacing: 0.18em; text-transform: uppercase;
      text-align: center; text-decoration: none;
      padding: 12px 8px;
      border: 1px solid rgba(255,255,255,0.12);
      color: var(--silver-light);
      transition: all 0.2s;
    }
    .mobile-sticky-btn:hover { background: rgba(255,255,255,0.06); }

    /* mobile */
    @media (max-width: 860px) {

      .mobile-sticky { display: flex; }
      
      .page-hero { padding: 40px 22px 50px; }
      .section { padding: 60px 22px; }

    }

    .tool-hero {
      padding: 100px 52px 60px;
      max-width: 1200px;
      margin: 0 auto;
      text-align: center;
    }
    .tool-hero-eyebrow {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.72rem;
      letter-spacing: 0.4em; color: var(--theme);
      text-transform: uppercase; margin-bottom: 24px;
    }
    .tool-hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300; font-size: clamp(2.6rem, 5.5vw, 4.5rem);
      letter-spacing: 0.01em; color: var(--white);
      line-height: 1.05; margin-bottom: 24px;
    }
    .tool-hero-title em { font-style: italic; color: var(--theme); }
    .tool-hero-sub {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-weight: 300;
      font-size: 1.3rem; color: var(--silver);
      max-width: 720px; margin: 0 auto;
      line-height: 1.5;
    }

    .promise-strip {
      max-width: 1100px;
      margin: 0 auto;
      padding: 40px 52px 60px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
      border-top: 1px solid rgba(255,255,255,0.05);
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .promise-cell {
      padding: 32px 24px;
      text-align: center;
      border-right: 1px solid rgba(255,255,255,0.08);
    }
    .promise-cell:last-child { border-right: none; }
    .promise-num {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300; font-size: 2.4rem;
      color: var(--theme); line-height: 1; margin-bottom: 12px;
    }
    .promise-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.66rem;
      letter-spacing: 0.28em; color: var(--silver-mid);
      text-transform: uppercase; margin-bottom: 8px;
    }
    .promise-text {
      font-family: 'Barlow', sans-serif;
      font-weight: 300; font-size: 0.85rem;
      color: var(--silver-dark); line-height: 1.6;
    }

    .tool-form-section {
      max-width: 1100px;
      margin: 0 auto;
      padding: 80px 52px;
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 80px;
    }
    .tool-form-left h2 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300; font-size: clamp(2rem, 4vw, 2.8rem);
      color: var(--white); line-height: 1.15;
      margin-bottom: 24px;
    }
    .tool-form-left h2 em { font-style: italic; color: var(--theme); }
    .tool-form-left p {
      font-family: 'Barlow', sans-serif;
      font-weight: 300; font-size: 1rem;
      color: var(--silver-mid); line-height: 1.9;
      margin-bottom: 22px;
    }
    .what-happens {
      margin-top: 36px;
      padding-top: 30px;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .what-happens-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 600; font-size: 0.66rem;
      letter-spacing: 0.3em; color: var(--theme);
      text-transform: uppercase; margin-bottom: 18px;
    }
    .step-list { display: flex; flex-direction: column; gap: 18px; }
    .step-item {
      display: grid;
      grid-template-columns: 32px 1fr;
      gap: 14px;
      align-items: start;
    }
    .step-num {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 500; font-size: 1.1rem;
      color: var(--theme); line-height: 1.3;
    }
    .step-text {
      font-family: 'Barlow', sans-serif;
      font-weight: 300; font-size: 0.92rem;
      color: var(--silver-mid); line-height: 1.6;
    }

    .form-card {
      background: var(--near-black);
      padding: 48px 44px;
      border: 1px solid rgba(255,255,255,0.06);
    }
    .form-card-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300; font-size: 1.6rem;
      color: var(--white); line-height: 1.2;
      margin-bottom: 14px;
    }
    .form-card-title em { font-style: italic; color: var(--theme); }
    .form-card-sub {
      font-family: 'Barlow', sans-serif;
      font-weight: 300; font-size: 0.88rem;
      color: var(--silver-dark); line-height: 1.7;
      margin-bottom: 32px;
    }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
    .form-field { margin-bottom: 16px; }
    .form-label {
      display: block;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.66rem;
      letter-spacing: 0.22em; color: var(--silver-dark);
      text-transform: uppercase; margin-bottom: 8px;
    }
    .form-input, .form-select, .form-textare
    .form-input:focus, .form-select:focus, .form-textarea:focus {
      outline: none; border-color: var(--theme);
      background: rgba(255,255,255,0.02);
    }
    .form-submit { width: 100%; margin-top: 20px; padding: 18px; cursor: pointer; border: none; }
    .form-privacy {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 400; font-size: 0.62rem;
      letter-spacing: 0.18em; color: var(--silver-dark);
      text-transform: uppercase; text-align: center;
      margin-top: 16px;
    }

    .testimonial-section {
      max-width: 1000px;
      margin: 0 auto;
      padding: 60px 52px;
      text-align: center;
    }
    .testimonial-eyebrow {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.66rem;
      letter-spacing: 0.32em; color: var(--theme);
      text-transform: uppercase; margin-bottom: 18px;
    }
    .testimonial-quote {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-weight: 300;
      font-size: clamp(1.4rem, 2.8vw, 1.8rem);
      color: var(--white); line-height: 1.45;
      max-width: 800px; margin: 0 auto 24px;
    }
    .testimonial-attr {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 500; font-size: 0.7rem;
      letter-spacing: 0.28em; color: var(--silver-dark);
      text-transform: uppercase;
    }

    @media (max-width: 1024px) {
      .tool-form-section { grid-template-columns: 1fr; gap: 48px; }
      .promise-strip { grid-template-columns: 1fr; gap: 0; }
      .promise-cell { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.08); }
      .promise-cell:last-child { border-bottom: none; }
    }

    @media (max-width: 860px) {
      .tool-hero { padding: 90px 22px 40px; }
      .promise-strip { padding: 30px 22px 40px; }
      .tool-form-section { padding: 60px 22px; }
      .form-card { padding: 36px 24px; }
      .form-row { grid-template-columns: 1fr; }
      .testimonial-section { padding: 50px 22px; }
    }

    /* ── TOOLS ROOM: image hero + reveal (sky-cyan concierge) ── */
    .tool-hero {
      position: relative;
      max-width: none;
      padding: 130px 32px 90px;
      text-align: center;
      overflow: hidden;
      background: var(--tool-hero-img) center 38% / cover no-repeat;
    }
    .tool-hero::before {
      content: ''; position: absolute; inset: 0;
      background:
        linear-gradient(180deg, rgba(6,6,6,0.6) 0%, rgba(6,6,6,0.82) 62%, var(--black) 100%),
        radial-gradient(ellipse at 50% 120%, rgba(var(--theme-rgb),0.22), transparent 62%);
    }
    .tool-hero > * { position: relative; z-index: 1; }
    .tool-hero-imglabel {
      position: absolute; left: 0; right: 0; bottom: 0; z-index: 2;
      padding: 8px 14px; text-align: left;
      background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
      font-family: 'Barlow', sans-serif; font-size: 0.7rem; color: rgba(255,255,255,0.72);
    }
    .reveal {
      opacity: 0; transform: translateY(26px);
      transition: opacity 0.9s cubic-bezier(0.2,0.7,0.2,1), transform 0.9s cubic-bezier(0.2,0.7,0.2,1);
    }
    .reveal.is-in { opacity: 1; transform: none; }
    @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; transition: none; } }
</style>
